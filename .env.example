# ============================================================
# BLUE.Y — Environment Variables Reference
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── Required ─────────────────────────────────────────────────

# AI provider (default: DeepSeek — https://platform.deepseek.com)
AI_API_KEY=your-deepseek-api-key
AI_BASE_URL=https://api.deepseek.com/v1
AI_ROUTINE_MODEL=deepseek-chat
AI_INCIDENT_MODEL=deepseek-reasoner

# Telegram bot (get token from @BotFather, chat ID from @userinfobot)
TELEGRAM_BOT_TOKEN=123456:ABCdef...
TELEGRAM_CHAT_ID=-1001234567890
TELEGRAM_ADMIN_ID=123456789

# Kubernetes
KUBE_IN_CLUSTER=true
WATCH_NAMESPACES=default,monitoring
CLUSTER_NAME=my-cluster
AWS_REGION=us-east-1

# ── Jira (optional) ───────────────────────────────────────────

JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_PROJECT_KEY=OPS
JIRA_EMAIL=your-bot@company.com
JIRA_API_TOKEN=your-jira-api-token

# ── Slack (optional) ──────────────────────────────────────────
# Socket Mode — no public URL required
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_CHANNEL_ID=C0123456789

# ── Microsoft Teams (optional) ────────────────────────────────

TEAMS_APP_ID=your-azure-bot-app-id
TEAMS_APP_PASSWORD=your-azure-bot-app-password
TEAMS_TENANT_ID=your-azure-ad-tenant-id

# ── Vision AI — image analysis (optional) ────────────────────
# Free tier: Google Gemini (https://aistudio.google.com)

VISION_API_KEY=your-gemini-api-key
VISION_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
VISION_MODEL=gemini-2.0-flash

# ── Loki — log aggregation (optional) ────────────────────────

LOKI_URL=http://loki.monitoring.svc.cluster.local:3100

# ── Grafana (optional) ───────────────────────────────────────

GRAFANA_INTERNAL_URL=http://grafana.monitoring.svc.cluster.local:3000
GRAFANA_EXTERNAL_URL=https://grafana.example.com
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your-grafana-password

# ── Database read-only access (optional) ──────────────────────

DB_READONLY_USER=bluey_readonly
DB_READONLY_PASSWORD=your-readonly-password
# JSON array of databases BLUE.Y can query via /data command
DATABASE_REGISTRY=[{"name":"prod","host":"db.example.com","port":3306,"user":"bluey_readonly","database":"mydb","type":"mysql"}]

# ── Bitbucket (optional — for /deploy command) ────────────────

BB_WORKSPACE=your-workspace
BB_TOKEN=your-bitbucket-api-token
# JSON: repo → {branch, pipelineVar}
BB_PIPELINES={"my-backend":{"branch":"main"},"my-frontend":{"branch":"main"}}

# ── AWS WAF (optional — requires IRSA or AWS credentials) ─────

WAF_WEB_ACL_NAME=my-production-waf
WAF_SCOPE=REGIONAL
WAF_REGION=us-east-1
WAF_IP_SET_NAME=blocked-ips
WAF_AUTO_BLOCK_DURATION=1440

# ── Email ──────────────────────────────────────────────────────
# Option A — SMTP (works on any cluster: GKE, AKS, bare metal, EKS)
# Set SMTP_HOST to use SMTP. If not set, falls back to AWS SES (Option B).

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@yourcompany.com

# Option B — AWS SES (EKS with IRSA — no credentials needed if IRSA is set up)
# Only used if SMTP_HOST is NOT set.
# SES_REGION=us-east-1
# SES_ACCESS_KEY_ID=   # optional — only if not using IRSA
# SES_SECRET_ACCESS_KEY=

# ── Load monitoring ────────────────────────────────────────────
# JSON array — deployments to watch for memory/CPU pressure
LOAD_WATCH_LIST=[{"deployment":"backend","namespace":"prod","label":"Backend","memLimitMB":4096,"memWarnMB":3000,"memCritMB":3800,"cpuWarnPct":70,"nodeGroup":"workers","nodeGroupFull":"workers-xxxxx","maxReplicas":3,"minReplicas":1}]

# ── Production URLs — smoke tests (/smoketest command) ─────────

PRODUCTION_URLS=[{"name":"API","url":"https://api.example.com/health","expect":200},{"name":"Frontend","url":"https://app.example.com","expect":200}]

# ── Ping service map (/ping <service>) ─────────────────────────

PING_SERVICE_MAP={"api":"https://api.example.com/health","frontend":"https://app.example.com"}

# ── Team emails (/email <name>) ────────────────────────────────

TEAM_EMAILS={"ops":"ops@company.com","dev":"dev@company.com"}

# ── AI system context (cluster-specific knowledge for AI) ──────

AI_SYSTEM_CONTEXT=This cluster runs: backend (prod ns, Java 8, 18GB RAM), frontend (prod ns, Next.js).

# ── Scheduling ─────────────────────────────────────────────────

SCHEDULE_DAILY_REPORT=0 9 * * *

# ── Safety ─────────────────────────────────────────────────────

MAX_ACTIONS_PER_HOUR=5

# ── WhatsApp — Twilio (optional) ──────────────────────────────

TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
